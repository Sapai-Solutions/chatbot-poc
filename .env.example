# ── aras-fullstack-template — Environment Variables ───────────────────────────
# Copy this file to .env and fill in your values.
# .env is git-ignored and must NEVER be committed.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your actual values
#   docker compose up
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Chatbot POC
APP_URL=http://localhost:8080
APP_ENV=development
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Database ──────────────────────────────────────────────────────────────────
# These must match POSTGRES_DB / POSTGRES_USER / POSTGRES_PASSWORD below
POSTGRES_DB=chatbot_db
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=changeme

# Async URL (used by FastAPI / SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://chatbot:changeme@db:5432/chatbot_db
# Sync URL (used by Alembic migrations)
DATABASE_URL_SYNC=postgresql://chatbot:changeme@db:5432/chatbot_db

# ── Redis & Celery ────────────────────────────────────────────────────────────
# Use separate Redis DB numbers to avoid key collisions:
#   /0 — app cache
#   /1 — Celery broker (task queue)
#   /2 — Celery result backend
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TASK_SOFT_TIME_LIMIT=900
CELERY_TASK_TIME_LIMIT=1200

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(50))"
JWT_SECRET=change-this-jwt-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=72

# ── Email (optional) ──────────────────────────────────────────────────────────
# Leave blank in development to disable email sending
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Chatbot POC

# ── Cache ─────────────────────────────────────────────────────────────────────
CACHE_TTL=300

# ── LLM Configuration ─────────────────────────────────────────────────────────
# Qwen3.5-27B deployed model (GPU-5/6 on HGPU122)
LLM_MODEL=Qwen3.5-27B
LLM_BASE_URL=http://100.71.19.113:8998/v1
LLM_API_KEY=not-needed
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ── Knowledge Base / RAG (optional) ───────────────────────────────────────────
# Configure to enable RAG queries from the chatbot
# Examples: http://your-rag-service:8000, https://api.example.com/rag
KNOWLEDGE_BASE_URL=
KNOWLEDGE_BASE_API_KEY=

# ── Celery profiles (optional) ────────────────────────────────────────────────
# Uncomment to always start Celery workers when running docker compose up
# COMPOSE_PROFILES=celery
